# =====================================================================
# AI-PMO 環境変数テンプレート
# このファイルをコピーして .env を作成し、各値を設定してください。
#   cp .env.example .env
# =====================================================================

# ----- Application -----
# JWTトークン署名用シークレット。下記コマンドで生成してください:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/ai_pmo

# ----- Vector DB (Qdrant) -----
QDRANT_URL=http://localhost:6335

# ----- LLM (LM Studio) -----
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL_NAME=qwen3.6-35b-a3b-ud-mlx
LLM_TIMEOUT_SECONDS=300

# ----- Gitea (Gitea起動・管理者トークン発行後に設定) -----
GITEA_BASE_URL=http://localhost:3000
# Gitea管理者アクセストークン: 設定 → アプリケーション → アクセストークン生成
GITEA_ADMIN_TOKEN=
# Webhook署名シークレット: 任意の文字列。Gitea Webhook設定と揃える
GITEA_WEBHOOK_SECRET=change-this-to-a-random-string

# ----- Auth -----
ACCESS_TOKEN_EXPIRE_HOURS=12
